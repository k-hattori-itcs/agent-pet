<Window x:Class="AgentCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AgentCompanion.Controls"
        Title="AgentCompanion" Width="240" Height="300"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid x:Name="Root" Background="Transparent">
        <StackPanel x:Name="PetStack"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom">
            <Border x:Name="StatusBubble"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,4"
                    Padding="9,5" CornerRadius="10"
                    Background="#E620232A" BorderBrush="#70FFFFFF"
                    BorderThickness="1" Visibility="Visible"
                    Width="210" MaxHeight="58" ClipToBounds="True">
                <TextBlock x:Name="StatusBubbleText"
                           Foreground="White" FontSize="10"
                           TextAlignment="Center" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" LineHeight="14"/>
            </Border>

            <Grid x:Name="PetStage" HorizontalAlignment="Center">
                <Ellipse x:Name="RingTrack"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Stroke="#40333845" StrokeThickness="4"
                         Fill="Transparent"/>
                <Ellipse x:Name="RingTrackSecondary"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Stroke="#302A3A52" StrokeThickness="3"
                         Fill="Transparent"/>
                <Path x:Name="RingProgressSecondary"
                      Stroke="#63A7FF" StrokeThickness="3"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Fill="Transparent"/>
                <Path x:Name="RingProgress"
                      Stroke="#42D392" StrokeThickness="4"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Fill="Transparent"/>
                <Border x:Name="RingBadge"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Padding="6,2" CornerRadius="8"
                        Background="#E620232A" BorderBrush="#60FFFFFF"
                        BorderThickness="1">
                    <TextBlock x:Name="RingBadgeText"
                               Foreground="White" FontSize="10"/>
                </Border>
                <controls:PetSprite x:Name="PetSprite"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
